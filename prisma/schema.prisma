// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// ข้อมูลบริษัท (Company Settings)
// ========================================
model Company {
  id            String   @id @default(cuid())
  nameTh        String   // ชื่อบริษัท (ภาษาไทย)
  nameEn        String   // ชื่อบริษัท (ภาษาอังกฤษ)
  addressTh     String   // ที่อยู่ (ภาษาไทย)
  addressEn     String?  // ที่อยู่ (ภาษาอังกฤษ)
  taxId         String   // เลขผู้เสียภาษี
  phones        String[] // เบอร์โทร
  email         String?  // E-mail
  logo          String?  // URL โลโก้บริษัท
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bankAccounts  BankAccount[]
}

model BankAccount {
  id            String   @id @default(cuid())
  bank          String   // ชื่อธนาคาร
  branch        String   // สาขา
  accountName   String   // ชื่อบัญชี
  accountNumber String   // เลขที่บัญชี
  accountType   String   // ประเภท (ออมทรัพย์/กระแสรายวัน)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

// ========================================
// ผู้ใช้งาน (Users)
// ========================================
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          UserRole @default(STAFF)
  avatar        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quotations    Quotation[]
  workOrders    WorkOrder[]
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  ACCOUNTANT
}

// ========================================
// ข้อมูลลูกค้า (Customers)
// ========================================
model CustomerGroup {
  id               String   @id @default(cuid())
  groupName        String   // ชื่อกลุ่มลูกค้า (บริษัท)
  headOfficeAddress String  // ที่อยู่สำนักงานใหญ่
  taxId            String?  // เลขผู้เสียภาษี
  contactName      String?  // ชื่อผู้ติดต่อ
  contactPhone     String?  // เบอร์ติดต่อ
  contactEmail     String?  // อีเมลติดต่อ
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  branches         CustomerBranch[]
  quotations       Quotation[]
}

model CustomerBranch {
  id              String        @id @default(cuid())
  code            String        // รหัสสาขา (เช่น store036)
  name            String        // ชื่อสาขา
  address         String?       // ที่อยู่สาขา
  contactName     String?       // ชื่อผู้ติดต่อสาขา
  contactPhone    String?       // เบอร์ผู้ติดต่อสาขา
  customerGroupId String
  customerGroup   CustomerGroup @relation(fields: [customerGroupId], references: [id], onDelete: Cascade)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())

  quotations      Quotation[]
  workOrders      WorkOrder[]
}

// ========================================
// ข้อมูลทีมช่าง (Technician Teams)
// ========================================
model TechnicianTeam {
  id            String          @id @default(cuid())
  teamName      String          // ชื่อทีม
  leaderName    String          // ชื่อหัวหน้าช่าง
  leaderPhone   String?         // เบอร์โทรหัวหน้า
  leaderIdCard  String?         // เลขบัตรประชาชนหัวหน้า
  leaderAddress String?         // ที่อยู่หัวหน้า
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  members       TeamMember[]
  workOrders    WorkOrder[]
  purchaseOrders PurchaseOrder[]
}

model TeamMember {
  id              String         @id @default(cuid())
  name            String         // ชื่อสมาชิก
  phone           String?        // เบอร์โทร
  idCard          String?        // เลขบัตรประชาชน
  teamId          String
  team            TechnicianTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
}

// ========================================
// ใบเสนอราคา (Quotations)
// ========================================
model Quotation {
  id              String           @id @default(cuid())
  quotationNumber String           @unique // เลขที่ใบเสนอราคา (Npk-YYMMDD-XXX)
  revisionNumber  Int              @default(0) // revision number
  date            DateTime         // วันที่
  customerGroupId String
  customerGroup   CustomerGroup    @relation(fields: [customerGroupId], references: [id])
  branchId        String?
  branch          CustomerBranch?  @relation(fields: [branchId], references: [id])
  contactPerson   String?          // ผู้ติดต่อ
  contactPhone    String?          // เบอร์โทรผู้ติดต่อ
  projectName     String?          // ชื่อโครงการ/งาน
  subtotal        Decimal          @default(0) @db.Decimal(12, 2) // ยอดรวมก่อน VAT
  discountPercent Decimal          @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(12, 2)
  vatPercent      Decimal          @default(7) @db.Decimal(5, 2)
  vatAmount       Decimal          @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal          @default(0) @db.Decimal(12, 2) // ยอดรวมสุทธิ
  status          QuotationStatus  @default(DRAFT)
  notes           String?          // หมายเหตุ
  conditions      String?          // เงื่อนไข
  validDays       Int              @default(30) // จำนวนวันที่เสนอราคามีผล
  warranty        String?          // เงื่อนไขรับประกัน (legacy)
  createdById     String
  createdBy       User             @relation(fields: [createdById], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  items           QuotationItem[]
  workOrders      WorkOrder[]
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

model QuotationItem {
  id            String    @id @default(cuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  itemOrder     Int       // ลำดับรายการ
  itemType      String    @default("ITEM") // HEADER or ITEM
  parentIndex   Int?      // parent header index for sub-items
  description   String    // รายละเอียด
  unit          String    @default("") // หน่วย
  quantity      Decimal   @default(0) @db.Decimal(10, 2) // จำนวน
  unitPrice     Decimal   @default(0) @db.Decimal(12, 2) // ราคาต่อหน่วย (unitPrice = materialPrice when no split)
  materialPrice Decimal   @default(0) @db.Decimal(12, 2) // ราคาวัสดุ
  labourPrice   Decimal   @default(0) @db.Decimal(12, 2) // ราคาค่าแรง
  amount        Decimal   @default(0) @db.Decimal(12, 2) // จำนวนเงิน
}

// ========================================
// ตอบรับทำงาน (Work Orders) - WO/PO
// ========================================
model WorkOrder {
  id              String           @id @default(cuid())
  woNumber        String           @unique // เลขที่ WO
  quotationId     String?
  quotation       Quotation?       @relation(fields: [quotationId], references: [id])
  branchId        String?
  branch          CustomerBranch?  @relation(fields: [branchId], references: [id])
  teamId          String?
  team            TechnicianTeam?  @relation(fields: [teamId], references: [id])
  date            DateTime
  startDate       DateTime?        // วันเริ่มงาน
  endDate         DateTime?        // วันสิ้นสุดงาน
  description     String?          // รายละเอียดงาน
  totalAmount     Decimal          @default(0) @db.Decimal(12, 2)
  status          WorkOrderStatus  @default(PENDING)
  notes           String?
  createdById     String
  createdBy       User             @relation(fields: [createdById], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  purchaseOrders  PurchaseOrder[]
  invoices        Invoice[]
}

enum WorkOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PAID
  CANCELLED
}

// ========================================
// ใบสั่งซื้อให้ช่าง (Purchase Orders)
// ========================================
model PurchaseOrder {
  id              String           @id @default(cuid())
  poNumber        String           @unique // เลขที่ PO
  workOrderId     String?
  workOrder       WorkOrder?       @relation(fields: [workOrderId], references: [id])
  teamId          String?
  team            TechnicianTeam?  @relation(fields: [teamId], references: [id])
  date            DateTime
  totalAmount     Decimal          @default(0) @db.Decimal(12, 2)
  status          POStatus         @default(DRAFT)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  items           PurchaseOrderItem[]
}

enum POStatus {
  DRAFT
  APPROVED
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemOrder       Int
  description     String
  unit            String
  quantity        Decimal       @db.Decimal(10, 2)
  unitPrice       Decimal       @db.Decimal(12, 2)
  amount          Decimal       @db.Decimal(12, 2)
}

// ========================================
// ใบแจ้งหนี้ (Invoices)
// ========================================
model Invoice {
  id              String         @id @default(cuid())
  invoiceNumber   String         @unique // เลขที่ใบแจ้งหนี้
  workOrderId     String?
  workOrder       WorkOrder?     @relation(fields: [workOrderId], references: [id])
  date            DateTime
  dueDate         DateTime       // วันครบกำหนดชำระ
  subtotal        Decimal        @default(0) @db.Decimal(12, 2)
  vatPercent      Decimal        @default(7) @db.Decimal(5, 2)
  vatAmount       Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal        @default(0) @db.Decimal(12, 2)
  status          InvoiceStatus  @default(UNPAID)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  taxInvoice      TaxInvoice?
  receiptVoucher  ReceiptVoucher?
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

// ========================================
// ใบกำกับภาษี (Tax Invoices)
// ========================================
model TaxInvoice {
  id                String   @id @default(cuid())
  taxInvoiceNumber  String   @unique // เลขที่ใบกำกับภาษี
  invoiceId         String   @unique
  invoice           Invoice  @relation(fields: [invoiceId], references: [id])
  date              DateTime
  subtotal          Decimal  @default(0) @db.Decimal(12, 2)
  vatAmount         Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal  @default(0) @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime @default(now())
}

// ========================================
// ใบสำคัญรับ (Receipt Vouchers)
// ========================================
model ReceiptVoucher {
  id              String        @id @default(cuid())
  voucherNumber   String        @unique // เลขที่ใบสำคัญรับ
  invoiceId       String?       @unique
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
  date            DateTime
  amount          Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(TRANSFER)
  bankName        String?       // ชื่อธนาคาร
  chequeNumber    String?       // เลขที่เช็ค
  chequeDate      DateTime?     // วันที่เช็ค
  notes           String?
  createdAt       DateTime      @default(now())
}

// ========================================
// ใบสำคัญจ่าย (Payment Vouchers)
// ========================================
model PaymentVoucher {
  id              String        @id @default(cuid())
  voucherNumber   String        @unique // เลขที่ใบสำคัญจ่าย
  date            DateTime
  payeeName       String        // ชื่อผู้รับเงิน
  amount          Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(TRANSFER)
  bankName        String?
  chequeNumber    String?
  chequeDate      DateTime?
  description     String?       // รายละเอียดการจ่าย
  notes           String?
  createdAt       DateTime      @default(now())

  withholdingTax  WithholdingTax?
}

enum PaymentMethod {
  CASH
  TRANSFER
  CHEQUE
}

// ========================================
// หนังสือรับรองหัก ณ ที่จ่าย (50 ทวิ)
// ========================================
model WithholdingTax {
  id                String         @id @default(cuid())
  whtNumber         String         @unique // เลขที่
  paymentVoucherId  String         @unique
  paymentVoucher    PaymentVoucher @relation(fields: [paymentVoucherId], references: [id])
  payeeName         String         // ชื่อผู้ถูกหัก
  payeeTaxId        String?        // เลขผู้เสียภาษี
  payeeAddress      String?        // ที่อยู่
  incomeType        String         // ประเภทเงินได้
  taxRate           Decimal        @db.Decimal(5, 2) // อัตราภาษี (%)
  incomeAmount      Decimal        @db.Decimal(12, 2) // จำนวนเงินที่จ่าย
  taxAmount         Decimal        @db.Decimal(12, 2) // ภาษีที่หัก
  date              DateTime
  notes             String?
  createdAt         DateTime       @default(now())
}
